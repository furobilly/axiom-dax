// ─── Typewriter ───────────────────────────────────
function typewrite(id, text, speed, done){
  clearTimeout(twTimer);
  const el=document.getElementById(id);
  const cur=document.getElementById('veraCursor');
  if(cur) cur.style.display='inline-block';
  let i=0; el.textContent='';
  function next(){
    if(i<text.length){ el.textContent+=text[i++]; twTimer=setTimeout(next,speed||36); }
    else{ if(cur) cur.style.display='none'; if(done) done(); }
  }
  next();
}

// ─── Mission load ─────────────────────────────────
function loadMission(mod){
  const u=getU();
  const m=MISSIONS[mod]||MISSIONS[0];
  document.getElementById('mName').textContent  = u?.name||'Analista';
  document.getElementById('mBadge').textContent = m.badge;
  document.getElementById('storyEl').innerHTML  = m.story;
  document.getElementById('objsEl').innerHTML   = m.objs.map(o=>`<div class="obj">${o}</div>`).join('');
  document.getElementById('rulesEl').innerHTML  = m.rules;
  setTimeout(()=>typewrite('veraTW', m.vera, 34), 1000);
}

