<script>
/* ═══════════════════════════════════════════════════
   AXIOM GAME ENGINE — Audio + Mission + VERA
═══════════════════════════════════════════════════ */

// ─── State ────────────────────────────────────────
const uid    = new URLSearchParams(location.search).get('u');
const getU   = () => (JSON.parse(localStorage.getItem('axiom_users')||'[]')).find(u=>u.id===uid)||null;
let musicOn  = true;
let sfxOn    = true;
let audioCtx = null;
let mNodes   = {};
let twTimer  = null;

// ─── Module content ───────────────────────────────
const MISSIONS = {
  0: {
    badge: 'MÓDULO 0 — EL DESPERTAR',
    vera:  'Recluta. Llevas 47 días de retraso. No hay tiempo para café. Bienvenido a AXIOM.',
    story: `<p>Eres el nuevo <strong>Analista JR de Sistemas</strong> en <em>AXIOM Motors GDL</em>.</p>
            <p>Tu primera semana debería haber sido inducción, presentaciones y café con el equipo.</p>
            <p>Pero <strong>The Void</strong> llegó primero.</p>
            <p>Roberto, el Gerente Regional, lleva <strong>47 horas sin poder ver un solo dato</strong>. Los reportes de ventas, inventario y finanzas están corrompidos.</p>
            <p class="story-hl">Cada fórmula que escribas correctamente restaura un nodo del sistema.</p>`,
    objs:  ['Entender qué es DAX','Lógica IF y operadores','SUMX — iterar datos','Variables VAR'],
    rules: `<strong>⚡ Reglas del protocolo:</strong> No puedes avanzar sin completar el ejercicio anterior. Si te atascas, recibirás pistas progresivas de VERA. Nadie aprende DAX leyendo — lo aprenden haciendo.`
  },
  1: {
    badge: 'MÓDULO 1 — LOS CIMIENTOS',
    vera:  'El modelo está roto. Sin estructura, ninguna fórmula tiene sentido. Vamos a reconstruirlo.',
    story: `<p>Los datos llegaron... pero sin orden.</p>
            <p>La <strong>base de AXIOM Motors</strong> tiene tablas mezcladas, relaciones rotas y un calendario inexistente.</p>
            <p>El equipo de BI está paralizado. <strong>Sin un modelo estrella correcto</strong>, ningún reporte funciona.</p>
            <p class="story-hl">Tu misión: reconstruir los cimientos de datos de la ciudad.</p>`,
    objs:  ['Modelo estrella ⭐','Hechos vs Dimensiones','Relaciones uno a muchos','Tabla Calendario'],
    rules: `<strong>⚡ Reglas del protocolo:</strong> El modelo es el corazón de DAX. Si el modelo falla, todo falla. Domina esto antes de continuar.`
  }
};

// ─── Audio Engine ─────────────────────────────────
function getAC(){
  if(!audioCtx) audioCtx=new(window.AudioContext||window.webkitAudioContext)();
  if(audioCtx.state==='suspended') audioCtx.resume();
  return audioCtx;
}

function startMusic(){
  if(!musicOn) return;
  stopMusic();
  try{
    const ac=getAC();
    const master=ac.createGain(); master.gain.value=.055; master.connect(ac.destination);

    // Sub drone
    const drone=ac.createOscillator(); drone.type='sawtooth'; drone.frequency.value=55;
    const dFilt=ac.createBiquadFilter(); dFilt.type='lowpass'; dFilt.frequency.value=110;
    const dGain=ac.createGain(); dGain.gain.value=.45;
    drone.connect(dFilt); dFilt.connect(dGain); dGain.connect(master); drone.start();

    // LFO pulse on drone
    const lfo=ac.createOscillator(); lfo.frequency.value=.38;
    const lGain=ac.createGain(); lGain.gain.value=14;
    lfo.connect(lGain); lGain.connect(drone.frequency); lfo.start();

    // Mid pads
    [110,165,220,277].forEach((f,i)=>{
      const o=ac.createOscillator(); o.type='triangle'; o.frequency.value=f;
      const g=ac.createGain(); g.gain.value=.14-i*.022;
      const bf=ac.createBiquadFilter(); bf.type='bandpass'; bf.frequency.value=f*1.6; bf.Q.value=2.5;
      o.connect(bf); bf.connect(g); g.connect(master); o.start();
      mNodes['pad'+i]=o;
    });

    // Hi shimmer arpeggio
    const hFreqs=[880,1108,1320,1760]; let hs=0;
    mNodes.shim=setInterval(()=>{
      if(!musicOn) return;
      try{
        const o=ac.createOscillator(); o.type='sine'; o.frequency.value=hFreqs[hs%hFreqs.length];
        const g=ac.createGain();
        g.gain.setValueAtTime(.013,ac.currentTime);
        g.gain.exponentialRampToValueAtTime(.0001,ac.currentTime+.38);
        o.connect(g); g.connect(master); o.start(); o.stop(ac.currentTime+.4);
        hs++;
      }catch(e){}
    },440);

    // Kick pulse
    mNodes.kick=setInterval(()=>{
      if(!musicOn) return;
      try{
        const o=ac.createOscillator(); o.type='sine';
        o.frequency.setValueAtTime(115,ac.currentTime);
        o.frequency.exponentialRampToValueAtTime(38,ac.currentTime+.18);
        const g=ac.createGain();
        g.gain.setValueAtTime(.48,ac.currentTime);
        g.gain.exponentialRampToValueAtTime(.001,ac.currentTime+.22);
        o.connect(g); g.connect(master); o.start(); o.stop(ac.currentTime+.24);
      }catch(e){}
    },820);

    mNodes.drone=drone; mNodes.lfo=lfo; mNodes.master=master;
  }catch(e){ console.warn('Audio:',e); }
}

function stopMusic(){
  try{
    clearInterval(mNodes.shim); clearInterval(mNodes.kick);
    ['drone','lfo','pad0','pad1','pad2','pad3'].forEach(k=>{ try{mNodes[k]?.stop();}catch(e){} });
    mNodes={};
  }catch(e){}
}

function sfx(type){
  if(!sfxOn) return;
  try{
    const ac=getAC();
    const master=ac.createGain(); master.connect(ac.destination);
    if(type==='correct'){
      [523,659,784].forEach((f,i)=>{
        const o=ac.createOscillator(); o.type='sine'; o.frequency.value=f;
        const g=ac.createGain();
        g.gain.setValueAtTime(.0001,ac.currentTime+i*.12);
        g.gain.linearRampToValueAtTime(.18,ac.currentTime+i*.12+.05);
        g.gain.exponentialRampToValueAtTime(.001,ac.currentTime+i*.12+.4);
        o.connect(g); g.connect(master);
        o.start(ac.currentTime+i*.12); o.stop(ac.currentTime+i*.12+.45);
      });
    } else if(type==='wrong'){
      const o=ac.createOscillator(); o.type='sawtooth';
      o.frequency.setValueAtTime(220,ac.currentTime);
      o.frequency.exponentialRampToValueAtTime(75,ac.currentTime+.22);
      const g=ac.createGain();
      g.gain.setValueAtTime(.12,ac.currentTime);
      g.gain.exponentialRampToValueAtTime(.001,ac.currentTime+.25);
      o.connect(g); g.connect(master); o.start(); o.stop(ac.currentTime+.28);
    } else if(type==='levelup'){
      [523,659,784,1047].forEach((f,i)=>{
        const o=ac.createOscillator(); o.type='triangle'; o.frequency.value=f;
        const g=ac.createGain();
        g.gain.setValueAtTime(.0001,ac.currentTime+i*.1);
        g.gain.linearRampToValueAtTime(.22,ac.currentTime+i*.1+.08);
        g.gain.exponentialRampToValueAtTime(.001,ac.currentTime+i*.1+.65);
        o.connect(g); g.connect(master);
        o.start(ac.currentTime+i*.1); o.stop(ac.currentTime+i*.1+.7);
      });
    } else if(type==='accept'){
      [262,330,392,523,659,784].forEach((f,i)=>{
        const o=ac.createOscillator(); o.type='triangle'; o.frequency.value=f;
        const g=ac.createGain();
        g.gain.setValueAtTime(.0001,ac.currentTime+i*.065);
        g.gain.linearRampToValueAtTime(.2,ac.currentTime+i*.065+.055);
        g.gain.exponentialRampToValueAtTime(.001,ac.currentTime+i*.065+.55);
        o.connect(g); g.connect(master);
        o.start(ac.currentTime+i*.065); o.stop(ac.currentTime+i*.065+.6);
      });
    } else if(type==='click'){
      const o=ac.createOscillator(); o.type='square'; o.frequency.value=750;
      const g=ac.createGain();
      g.gain.setValueAtTime(.04,ac.currentTime);
      g.gain.exponentialRampToValueAtTime(.001,ac.currentTime+.05);
      o.connect(g); g.connect(master); o.start(); o.stop(ac.currentTime+.06);
    }
  }catch(e){}
}

