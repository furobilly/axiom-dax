// ─── Particles ────────────────────────────────────
const cv=document.getElementById('bg'), cx=cv.getContext('2d');
let pts=[];
function resize(){ cv.width=innerWidth; cv.height=innerHeight; initPts(); }
function initPts(){
  pts=[];
  for(let i=0;i<80;i++) pts.push({x:Math.random()*cv.width,y:Math.random()*cv.height,vx:(Math.random()-.5)*.3,vy:(Math.random()-.5)*.3,r:Math.random()*1.3+.5,a:Math.random()*.4+.1});
}
function drawBg(){
  cx.clearRect(0,0,cv.width,cv.height);
  cx.strokeStyle='rgba(0,212,255,.04)'; cx.lineWidth=1;
  for(let x=0;x<cv.width;x+=70){ cx.beginPath(); cx.moveTo(x,0); cx.lineTo(x,cv.height); cx.stroke(); }
  for(let y=0;y<cv.height;y+=70){ cx.beginPath(); cx.moveTo(0,y); cx.lineTo(cv.width,y); cx.stroke(); }
  pts.forEach((p,i)=>{
    pts.slice(i+1).forEach(q=>{ const d=Math.hypot(p.x-q.x,p.y-q.y); if(d<120){ cx.beginPath(); cx.strokeStyle=`rgba(0,212,255,${.07*(1-d/120)})`; cx.moveTo(p.x,p.y); cx.lineTo(q.x,q.y); cx.stroke(); } });
    cx.beginPath(); cx.arc(p.x,p.y,p.r,0,Math.PI*2); cx.fillStyle=`rgba(242,201,76,${p.a})`; cx.fill();
    p.x+=p.vx; p.y+=p.vy;
    if(p.x<0||p.x>cv.width) p.vx*=-1;
    if(p.y<0||p.y>cv.height) p.vy*=-1;
  });
  requestAnimationFrame(drawBg);
}

// ─── Boot ─────────────────────────────────────────
addEventListener('resize',resize);
resize(); drawBg();

if(!uid||!getU()){ location.href='index.html'; }
else {
  loadMission(getU()?.currentModule||0);
  // Audio starts on first user interaction (browser policy)
  document.addEventListener('click',function boot(){
    startMusic();
    document.removeEventListener('click',boot);
  },{once:true});
}
