<!DOCTYPE html>
<html lang="es">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>AXIOM — La Ciudad de los Datos</title>
  <link href="https://fonts.googleapis.com/css2?family=Orbitron:wght@400;700;900&family=Exo+2:ital,wght@0,300;0,400;0,600;1,300&display=swap" rel="stylesheet">
  <style>
    :root {
      --bg:#0D0D1A; --panel:#1A1A2E; --gold:#F2C94C;
      --cyan:#00D4FF; --red:#FF4D6D; --green:#00F5A0;
      --purple:#A855F7; --text:#E8E8F0; --dim:#7777AA;
    }
    body.light { --bg:#EEF0FF; --panel:#FFFFFF; --text:#0D0D1A; --dim:#5555AA; }
    *,*::before,*::after{margin:0;padding:0;box-sizing:border-box;}
    body{background:var(--bg);color:var(--text);font-family:'Exo 2',sans-serif;min-height:100vh;overflow-x:hidden;transition:background .4s,color .4s;}
    body::after{content:'';position:fixed;inset:0;background:repeating-linear-gradient(0deg,transparent,transparent 2px,rgba(0,0,0,.025) 2px,rgba(0,0,0,.025) 4px);pointer-events:none;z-index:9999;}
    canvas#bg{position:fixed;inset:0;z-index:0;pointer-events:none;}

    /* ── Top bar ── */
    .top-bar{position:fixed;top:0;left:0;right:0;z-index:200;display:flex;align-items:center;justify-content:space-between;padding:.65rem 1.4rem;background:rgba(13,13,26,.88);border-bottom:1px solid rgba(242,201,76,.1);backdrop-filter:blur(8px);}
    .bar-logo{font-family:'Orbitron',monospace;font-size:.85rem;letter-spacing:.3em;color:var(--gold);}
    .bar-right{display:flex;gap:.5rem;align-items:center;}
    .icon-btn{background:rgba(255,255,255,.04);border:1px solid rgba(255,255,255,.1);color:var(--dim);padding:.3rem .65rem;cursor:pointer;font-size:.85rem;transition:all .3s;border-radius:2px;}
    .icon-btn:hover{color:var(--text);border-color:rgba(255,255,255,.25);}
    .icon-btn.on{color:var(--gold);border-color:rgba(242,201,76,.5);}

    /* ── Scene ── */
    .scene{position:relative;z-index:10;min-height:100vh;display:flex;align-items:center;justify-content:center;padding:5rem 1.5rem 2rem;}
    .mission-layout{display:flex;align-items:flex-start;justify-content:center;gap:2rem;max-width:1000px;width:100%;animation:fadeUp .7s ease both;}
    @keyframes fadeUp{from{opacity:0;transform:translateY(22px)}to{opacity:1;transform:none}}

    /* ── VERA panel ── */
    .vera-panel{flex-shrink:0;width:210px;display:flex;flex-direction:column;align-items:center;gap:.75rem;}
    .vera-wrap{width:190px;height:280px;position:relative;}
    .vera-wrap::before{content:'';position:absolute;bottom:-8px;left:50%;transform:translateX(-50%);width:130px;height:16px;background:radial-gradient(ellipse,rgba(0,212,255,.5) 0%,transparent 70%);filter:blur(4px);animation:pulse 2.5s ease-in-out infinite;}
    @keyframes pulse{0%,100%{opacity:.55}50%{opacity:1}}
    .vera-fig{width:100%;height:100%;filter:drop-shadow(0 0 10px rgba(0,212,255,.55));animation:holoFlick 8s ease-in-out infinite;}
    @keyframes holoFlick{0%,100%{opacity:1}5%{opacity:.65}10%{opacity:1}15%{opacity:.35}20%{opacity:1}88%{opacity:1}92%{opacity:.6}96%{opacity:1}}
    .vera-name{font-family:'Orbitron',monospace;font-size:.7rem;letter-spacing:.28em;color:var(--cyan);text-shadow:0 0 10px rgba(0,212,255,.5);}
    .vera-dot{font-size:.68rem;color:var(--dim);display:flex;align-items:center;gap:.4rem;}
    .vera-dot::before{content:'';width:6px;height:6px;border-radius:50%;background:var(--green);box-shadow:0 0 6px var(--green);animation:blink .8s infinite;flex-shrink:0;}
    @keyframes blink{0%,100%{opacity:1}50%{opacity:.25}}
    .vera-bubble{background:rgba(0,212,255,.06);border:1px solid rgba(0,212,255,.22);border-radius:4px;padding:.65rem .85rem;font-size:.78rem;font-style:italic;color:var(--cyan);line-height:1.65;position:relative;width:100%;}
    .vera-bubble::before{content:'';position:absolute;top:13px;right:-8px;border:4px solid transparent;border-left-color:rgba(0,212,255,.22);}
    .tw-cursor{display:inline-block;width:2px;height:.8em;background:var(--cyan);vertical-align:middle;animation:blink .6s infinite;}

    /* ── Mission card ── */
    .mission-card{flex:1;max-width:640px;background:var(--panel);border:1px solid rgba(242,201,76,.16);position:relative;overflow:hidden;}
    .mission-card::before{content:'';position:absolute;top:0;left:0;right:0;height:2px;background:linear-gradient(90deg,transparent,var(--gold),transparent);}
    .card-head{padding:1.5rem 1.8rem 1.1rem;border-bottom:1px solid rgba(255,255,255,.05);}
    .m-title{font-family:'Orbitron',monospace;font-size:clamp(.95rem,2.5vw,1.2rem);color:var(--gold);letter-spacing:.07em;display:flex;align-items:center;gap:.65rem;flex-wrap:wrap;}
    .m-badge{font-size:.62rem;letter-spacing:.2em;background:rgba(242,201,76,.1);border:1px solid rgba(242,201,76,.28);color:var(--gold);padding:.18rem .55rem;}
    .card-body{padding:1.3rem 1.8rem;display:flex;flex-direction:column;gap:1.1rem;}

    .story-block{background:rgba(0,0,0,.22);border:1px solid rgba(0,212,255,.1);border-left:3px solid var(--cyan);padding:1rem 1.2rem;font-size:.88rem;line-height:1.85;color:var(--text);}
    .story-block p{margin:.45rem 0;}.story-block p:first-child{margin-top:0;}.story-block p:last-child{margin-bottom:0;}
    .story-block strong{color:var(--gold);font-weight:600;}
    .story-block em{color:var(--cyan);font-style:normal;font-weight:600;}
    .story-hl{color:var(--cyan);font-weight:600;font-size:.92rem;margin-top:.8rem!important;}

    .objs{display:flex;flex-wrap:wrap;gap:.45rem;}
    .obj{font-size:.7rem;letter-spacing:.06em;padding:.28rem .75rem;background:rgba(0,245,160,.06);border:1px solid rgba(0,245,160,.22);color:var(--green);border-radius:2px;}
    .obj::before{content:'✓ ';}

    .rules-block{background:rgba(242,201,76,.04);border:1px solid rgba(242,201,76,.13);padding:.85rem 1.1rem;font-size:.78rem;color:var(--dim);line-height:1.72;}
    .rules-block strong{color:var(--gold);}

    .card-foot{padding:1.1rem 1.8rem 1.5rem;}
    .btn-accept{width:100%;font-family:'Orbitron',monospace;font-size:.88rem;letter-spacing:.2em;padding:1rem 2rem;background:var(--gold);border:none;color:#0D0D1A;cursor:pointer;position:relative;overflow:hidden;transition:all .3s;display:flex;align-items:center;justify-content:center;gap:.6rem;}
    .btn-accept::before{content:'';position:absolute;inset:0;background:rgba(255,255,255,.18);transform:translateX(-101%);transition:transform .35s;}
    .btn-accept:hover::before{transform:translateX(0);}
    .btn-accept:hover{box-shadow:0 0 32px rgba(242,201,76,.45);}
    .btn-accept:active{transform:scale(.98);}
    .bolt{animation:boltPulse 1.6s ease-in-out infinite;}
    @keyframes boltPulse{0%,100%{transform:scale(1)}50%{transform:scale(1.25)}}

    /* ── Toast ── */
    .toast{position:fixed;bottom:1.5rem;right:1.5rem;z-index:500;background:var(--panel);border:1px solid var(--green);padding:.75rem 1.1rem;font-size:.8rem;color:var(--green);transform:translateY(80px);opacity:0;transition:all .4s;border-radius:2px;max-width:280px;}
    .toast.show{transform:none;opacity:1;}

    /* ── Responsive ── */
    @media(max-width:680px){
      .mission-layout{flex-direction:column;align-items:center;}
      .vera-panel{width:160px;flex-direction:row;flex-wrap:wrap;justify-content:center;}
      .vera-wrap{width:140px;height:200px;}
      .vera-bubble{font-size:.73rem;}
      .card-head,.card-body,.card-foot{padding-left:1.2rem;padding-right:1.2rem;}
    }
  </style>
</head>
<body>

